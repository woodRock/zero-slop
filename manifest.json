{
  "manifest_version": 3,
  "name": "ZeroSlop: ZeroGPT Tweet Checker",
  "version": "1.0.0",
  "description": "Instantly detect AI-generated tweets on Twitter (X) using the ZeroGPT Business API.",
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "https://api.zerogpt.com/*",
    "https://twitter.com/*",
    "https://x.com/*"
  ],
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://twitter.com/*",
        "https://x.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}